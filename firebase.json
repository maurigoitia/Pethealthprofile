        {
          "source": "/soluciones/medicacion",
          "destination": "/",
          "type": 301
        },
        {
          "source": "/soluciones/historial",
          "destination": "/",
          "type": 301
        },
        {
          "source": "/app",
          "destination": "/inicio",
          "type": 301
        },
        {
          "source": "/privacy",
          "destination": "/privacidad",
          "type": 301
        },
        {
          "source": "/terms",
          "destination": "/terminos",
          "type": 301
