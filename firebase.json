        {
          "source": "/privacy.html",
          "destination": "/privacidad",
          "type": 301
        },
        {
          "source": "/terms.html",
          "destination": "/terminos",
          "type": 301
        },
        {
          "source": "/data-deletion",
          "destination": "/data-deletion.html",
          "type": 301
        }
      ],
      "rewrites": [
        {
          "source": "/blog",
          "destination": "/blog.html"
        },
        {
          "source": "/blog/tu-mascota-todo-en-orden",
          "destination": "/blog/tu-mascota-todo-en-orden.html"
        },
        {
          "source": "/blog/vacunas-perros-argentina",
          "destination": "/blog/vacunas-perros-argentina.html"
        },
        {
          "source": "**",
          "destination": "/app.html"
        }
      ]
    },
    {
      "target": "appqa",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        {
          "source": "/data-deletion",
          "destination": "/data-deletion.html",
          "type": 301
        }
      ],
      "headers": [
        {
          "source": "/sw.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
