{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"],
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-*-debug.log"
      ]
    }
  ],
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": [
    {
    "target": "app",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/login",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, nofollow"
          }
        ]
      },
      {
        "source": "/home",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, nofollow"
          }
        ]
      },
      {
        "source": "/register",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, nofollow"
          }
        ]
      },
      {
        "source": "/register-user",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, nofollow"
          }
        ]
      },
      {
        "source": "/register-pet",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, nofollow"
          }
        ]
      },
      {
        "source": "/register-pet/**",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, nofollow"
          }
        ]
      },
      {
        "source": "/review/**",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, nofollow"
          }
        ]
      },
      {
        "source": "/email-link",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, nofollow"
          }
        ]
      },
      {
        "source": "/verify/**",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, nofollow"
          }
        ]
      }
    ],
    "redirects": [
      {
        "source": "/",
        "destination": "/inicio",
        "type": 301
      },
      {
        "source": "/welcome",
        "destination": "/inicio",
        "type": 301
      },
      {
        "source": "/onboarding",
        "destination": "/inicio",
        "type": 301
      },
      {
        "source": "/inicio/vacunas",
        "destination": "/inicio",
        "type": 301
      },
      {
        "source": "/inicio/medicacion",
        "destination": "/inicio",
        "type": 301
      },
      {
        "source": "/inicio/historial-medico",
        "destination": "/inicio",
        "type": 301
      },
      {
        "source": "/soluciones/vacunas",
        "destination": "/inicio",
        "type": 301
      },
      {
        "source": "/soluciones/medicacion",
        "destination": "/inicio",
        "type": 301
      },
      {
        "source": "/soluciones/historial",
        "destination": "/inicio",
        "type": 301
      },
      {
        "source": "/app",
        "destination": "/login",
        "type": 301
      },
      {
        "source": "/privacy",
        "destination": "/privacidad",
        "type": 301
      },
      {
        "source": "/terms",
        "destination": "/terminos",
        "type": 301
      },
      {
        "source": "/privacy.html",
        "destination": "/privacidad",
        "type": 301
      },
      {
        "source": "/terms.html",
        "destination": "/terminos",
        "type": 301
      },
      {
        "source": "/data-deletion",
        "destination": "/data-deletion.html",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/api/data-deletion-request",
        "function": "submitDataDeletionRequest"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  {
    "target": "appqa",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/data-deletion",
        "destination": "/data-deletion.html",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/api/data-deletion-request",
        "function": "submitDataDeletionRequest"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  {
    "target": "appit",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/data-deletion",
        "destination": "/data-deletion.html",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/api/data-deletion-request",
        "function": "submitDataDeletionRequest"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  {
    "target": "appfocusqa",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/data-deletion",
        "destination": "/data-deletion.html",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/api/data-deletion-request",
        "function": "submitDataDeletionRequest"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
]
}
