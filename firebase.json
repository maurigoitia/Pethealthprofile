          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "/api/data-deletion-request",
          "function": "submitDataDeletionRequest"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
