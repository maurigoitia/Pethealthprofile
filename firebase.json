      "redirects": [
        {
          "source": "/welcome",
          "destination": "/",
          "type": 301
        },
        {
          "source": "/onboarding",
          "destination": "/",
          "type": 301
        },
        {
          "source": "/inicio/vacunas",
          "destination": "/",
          "type": 301
        },
        {
          "source": "/inicio/medicacion",
          "destination": "/",
          "type": 301
        },
        {
          "source": "/inicio/historial-medico",
          "destination": "/",
          "type": 301
