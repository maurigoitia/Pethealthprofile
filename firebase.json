{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-*-debug.log"
      ]
    }
  ],
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "predeploy": ["bash pre-deploy-check.sh"],
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/app.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/blog",
        "destination": "/blog.html"
      },
      {
        "source": "/blog/",
        "destination": "/blog.html"
      },
      {
        "source": "/blog/alimentos-prohibidos-perros",
        "destination": "/blog/alimentos-prohibidos-perros/index.html"
      },
      {
        "source": "/blog/cada-cuanto-banar-perro",
        "destination": "/blog/cada-cuanto-banar-perro/index.html"
      },
      {
        "source": "/blog/tu-mascota-todo-en-orden",
        "destination": "/blog/tu-mascota-todo-en-orden/index.html"
      },
      {
        "source": "/blog/vacunas-perros-argentina",
        "destination": "/blog/vacunas-perros-argentina/index.html"
      },
      {
        "source": "/blog/desparasitar-perros-cachorros",
        "destination": "/blog/desparasitar-perros-cachorros/index.html"
      },
      {
        "source": "/blog/cuanto-duerme-un-gato-adulto",
        "destination": "/blog/cuanto-duerme-un-gato-adulto/index.html"
      },
      {
        "source": "/blog/moquillo-en-perros-sintomas",
        "destination": "/blog/moquillo-en-perros-sintomas/index.html"
      },
      {
        "source": "**",
        "destination": "/app.html"
      }
    ],
    "predeploy": [
      "bash pre-deploy-check.sh"
    ]
  }
}