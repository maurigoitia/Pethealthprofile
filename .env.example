# Firebase Web Push (FCM)
# Public key from Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
VITE_FIREBASE_VAPID_KEY=BG4wi3_yDKJa6XYueelKVk-Tz8qt2Adg34fzK5lhCduewZ-CyaPULVu8VqA2oP_jVz9FYpONPy68J_zV9KQ

# IA analysis routing
# false = llamada directa desde frontend (legacy)
# true  = Cloud Functions backend (recommended)
VITE_USE_BACKEND_ANALYSIS=false

# UI pending actions visibility
# true  = mostrar "Pendientes"
# false = ocultar "Pendientes"
# vacío = se oculta automáticamente en pessy.app y se muestra en QA
VITE_ENABLE_PENDING_ACTIONS=

# Email sync data visibility (Timeline / turnos / tratamientos importados)
# true  = mostrar eventos y entidades derivados de mails
# false = ocultarlos en UI
# vacío = true por defecto
VITE_ENABLE_EMAIL_SYNC=
