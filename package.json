{
  "name": "pessy-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:pwa",
    "dev:pwa": "vite",
    "dev:landing": "node scripts/serve-landing.js",
    "dev:blog": "node scripts/serve-blog.js",
    "build": "vite build",
    "build:pwa": "vite build",
    "build:mobile": "npm run build && cp dist/app.html dist/index.html && LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 npx cap sync",
    "cap:copy": "npx cap copy",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:sync": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 npx cap sync",
    "mobile:doctor": "npx cap doctor",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:chromium": "playwright test --project=chromium",
    "e2e:debug": "playwright test --debug",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "prebuild": "node scripts/sync-blog.js && node scripts/sync-website.js",
    "postbuild": "node scripts/postbuild-website.js"
  },
  "dependencies": {
    "@capacitor/app": "^7.1.1",
    "@capacitor/browser": "^7.0.2",
    "@capacitor/camera": "^7.0.0",
    "@capacitor/core": "^7.4.3",
    "@capacitor/push-notifications": "^7.0.6",
    "@rollup/rollup-darwin-arm64": "^4.60.0",
    "@sentry/react": "^10.47.0",
    "clsx": "2.1.1",
    "date-fns": "3.6.0",
    "firebase": "^12.9.0",
    "heic2any": "^0.0.4",
    "i18next": "^26.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.487.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "7.55.0",
    "react-i18next": "^17.0.2",
    "react-router": "7.13.0",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.7.0",
    "dotenv": "^17.4.0",
    "firebase-admin": "^13.8.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.2",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.1"
  },
  "overrides": {
    "serialize-javascript": ">=6.0.2",
    "dompurify": ">=3.2.4",
    "tar": ">=6.2.1"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5",
      "serialize-javascript": ">=6.0.2",
      "dompurify": ">=3.2.4",
      "tar": ">=6.2.1"
    }
  }
}
