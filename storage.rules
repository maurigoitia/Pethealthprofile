rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function validWriteSize() {
      return request.resource == null || request.resource.size < 30 * 1024 * 1024;
    }

    // SECURITY: Solo tipos de archivo permitidos (previene upload de ejecutables)
    // SCRUM-17: image/.* bloqueado — incluía SVG que puede tener JS embebido
    // Whitelist explícita: solo jpeg/png/webp/gif/pdf
    function isAllowedContentType() {
      return request.resource == null || (
        request.resource.contentType == 'image/jpeg' ||
        request.resource.contentType == 'image/jpg' ||
        request.resource.contentType == 'image/png' ||
        request.resource.contentType == 'image/webp' ||
        request.resource.contentType == 'image/gif' ||
        request.resource.contentType == 'application/pdf'
      );
    }

    // Perfil de usuario y assets de mascotas por usuario
    match /users/{userId}/{allPaths=**} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && validWriteSize() && isAllowedContentType();
    }

    // Documentos médicos subidos por el tutor
    // SECURITY: Solo el owner puede escribir, validando tipo de archivo
    match /documents/{userId}/{allPaths=**} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && validWriteSize() && isAllowedContentType();
    }
  }
}
