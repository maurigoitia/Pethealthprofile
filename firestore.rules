rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────────────────────────────────

    function signedIn() {
      return request.auth != null;
    }

    function petExists(petId) {
      return exists(/databases/$(database)/documents/pets/$(petId));
    }

    function petData(petId) {
      return get(/databases/$(database)/documents/pets/$(petId)).data;
    }

    function isPetOwnerById(petId) {
      return signedIn() && petExists(petId) && petData(petId).ownerId == request.auth.uid;
    }

    function canAccessPetById(petId) {
      return signedIn() && petExists(petId) && (
        petData(petId).ownerId == request.auth.uid ||
        (petData(petId).coTutorUids is list &&
          request.auth.uid in petData(petId).coTutorUids)
      );
    }

    function isPetOwner(pet) {
      return signedIn() && pet.ownerId == request.auth.uid;
    }

    function isPetCoTutor(pet) {
      return signedIn() && pet.coTutorUids is list && request.auth.uid in pet.coTutorUids;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    // ─────────────────────────────────────────────────────────────────
    // INVITE HELPERS
    // ─────────────────────────────────────────────────────────────────

    function canJoinPetWithInvite(petId) {
      return signedIn()
        && resource.data.coTutorUids is list
        && resource.data.coTutors is list
        && request.resource.data.coTutorUids is list
        && request.resource.data.coTutors is list
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'coTutors',
          'coTutorUids',
          'lastJoinInviteCode'
        ])
        && !resource.data.coTutorUids.hasAny([request.auth.uid])
        && request.resource.data.coTutorUids.hasAny([request.auth.uid])
        && request.resource.data.coTutorUids.size() == resource.data.coTutorUids.size() + 1
        && request.resource.data.coTutorUids.hasAll(resource.data.coTutorUids)
        && request.resource.data.coTutors.size() == resource.data.coTutors.size() + 1
        && request.resource.data.lastJoinInviteCode is string
        && exists(/databases/$(database)/documents/invitations/$(request.resource.data.lastJoinInviteCode))
        && get(/databases/$(database)/documents/invitations/$(request.resource.data.lastJoinInviteCode)).data.petId == petId
        && get(/databases/$(database)/documents/invitations/$(request.resource.data.lastJoinInviteCode)).data.createdBy == resource.data.ownerId
        && get(/databases/$(database)/documents/invitations/$(request.resource.data.lastJoinInviteCode)).data.used == false
        && (
          !(get(/databases/$(database)/documents/invitations/$(request.resource.data.lastJoinInviteCode)).data.expiresAt is timestamp) ||
          get(/databases/$(database)/documents/invitations/$(request.resource.data.lastJoinInviteCode)).data.expiresAt > request.time
        )
        && (
          get(/databases/$(database)/documents/invitations/$(request.resource.data.lastJoinInviteCode)).data.inviteEmail == null ||
          (
            request.auth.token.email != null &&
            get(/databases/$(database)/documents/invitations/$(request.resource.data.lastJoinInviteCode)).data.inviteEmail == request.auth.token.email
          )
        );
    }

    function canLeavePetAsCoTutor() {
      return signedIn()
        && resource.data.coTutorUids is list
        && resource.data.coTutors is list
        && request.resource.data.coTutorUids is list
        && request.resource.data.coTutors is list
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'coTutors',
          'coTutorUids'
        ])
        && resource.data.coTutorUids.hasAny([request.auth.uid])
        && !request.resource.data.coTutorUids.hasAny([request.auth.uid])
        && request.resource.data.coTutorUids.size() == resource.data.coTutorUids.size() - 1
        && resource.data.coTutorUids.hasAll(request.resource.data.coTutorUids)
        && request.resource.data.coTutors.size() == resource.data.coTutors.size() - 1;
    }

    // ─────────────────────────────────────────────────────────────────
    // USERS
    // ─────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;
      // Block self-promotion: plan/role/admin fields require Cloud Function (custom claim).
      // User puede tocar su doc pero no modificar campos sensibles.
      allow update: if signedIn() && request.auth.uid == userId
        && (!('plan' in request.resource.data) || request.resource.data.plan == resource.data.get('plan', null))
        && (!('planType' in request.resource.data) || request.resource.data.planType == resource.data.get('planType', null))
        && (!('subscriptionPlan' in request.resource.data) || request.resource.data.subscriptionPlan == resource.data.get('subscriptionPlan', null))
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.get('role', null))
        && (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == resource.data.get('isAdmin', false));
      allow delete: if signedIn() && request.auth.uid == userId;

      match /fcm_tokens/{tokenId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      match /pets/{petId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      // adopter_profile — perfil del user para matching de adopción
      // Solo el user puede leer/escribir su propio perfil
      match /adopter_profile/{docId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }

    // ─────────────────────────────────────────────────────────────────
    // PETS
    // ─────────────────────────────────────────────────────────────────

    match /pets/{petId} {
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      // Read: solo owner o co-tutor. Feature QR/perfil público removida 2026-04-25.
      allow read: if
        isPetOwner(resource.data) ||
        isPetCoTutor(resource.data);
      // SCRUM-16: co-tutors solo pueden modificar campos whitelisted
      allow update: if
        isPetOwner(resource.data) ||
        (
          isPetCoTutor(resource.data) &&
          request.resource.data.ownerId == resource.data.ownerId &&
          request.resource.data.coTutorUids == resource.data.coTutorUids &&
          request.resource.data.coTutors == resource.data.coTutors &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'petNotes',
            'appointments',
            'lastUpdatedBy',
            'lastUpdatedAt'
          ])
        ) ||
        canJoinPetWithInvite(petId) ||
        canLeavePetAsCoTutor();
      allow delete: if isPetOwner(resource.data);

      // ─── EXTRACTED VETS (populated by Cloud Function `extractVetsFromArchives`
      //     + incremental client upserts desde MedicalContext tras addEvent).
      // Read/write: owner o co-tutor del pet. La CF usa admin SDK y bypasea rules.
      match /extractedVets/{vetId} {
        allow read, create, update: if canAccessPetById(petId);
        allow delete: if isPetOwnerById(petId);
      }
    }

    // ─────────────────────────────────────────────────────────────────
    // ACCESS REQUESTS (beta gate)
    // ─────────────────────────────────────────────────────────────────

    match /access_requests/{docId} {
      allow create: if request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasAll(['name', 'email', 'source', 'status', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.name.size() > 0
        && request.resource.data.email.size() > 5;
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // ─────────────────────────────────────────────────────────────────
    // INVITATIONS
    // ─────────────────────────────────────────────────────────────────

    match /invitations/{code} {
      allow create: if signedIn() && code.matches('^[A-Z0-9]{6}$') && (
        (
          request.resource.data.createdBy == request.auth.uid
          && request.resource.data.petId is string
          && isPetOwnerById(request.resource.data.petId)
          && request.resource.data.used == false
        )
        ||
        (
          request.resource.data.type == 'platform'
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.used == false
        )
      );

      allow get: if
        (resource.data.type == 'platform')
        ||
        (signedIn() && (
          resource.data.createdBy == request.auth.uid ||
          resource.data.inviteEmail == null ||
          (
            request.auth.token.email != null &&
            resource.data.inviteEmail is string &&
            resource.data.inviteEmail == request.auth.token.email
          )
        ));
      allow list: if false;

      allow update: if signedIn() && (
        resource.data.createdBy == request.auth.uid ||
        (
          resource.data.used == false &&
          request.resource.data.createdBy == resource.data.createdBy &&
          request.resource.data.petId == resource.data.petId &&
          request.resource.data.expiresAt == resource.data.expiresAt &&
          request.resource.data.petName == resource.data.petName &&
          request.resource.data.used == true &&
          request.resource.data.usedBy == request.auth.uid &&
          (
            resource.data.inviteEmail == null ||
            (
              request.auth.token.email != null &&
              resource.data.inviteEmail is string &&
              resource.data.inviteEmail == request.auth.token.email
            )
          ) &&
          petExists(resource.data.petId) &&
          petData(resource.data.petId).coTutorUids is list &&
          petData(resource.data.petId).coTutorUids.hasAny([request.auth.uid]) &&
          (
            !(resource.data.expiresAt is timestamp) ||
            resource.data.expiresAt > request.time
          ) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['used', 'usedBy', 'usedAt'])
        )
        ||
        (
          resource.data.type == 'platform' &&
          resource.data.used == false &&
          request.resource.data.used == true &&
          request.resource.data.usedBy == request.auth.uid &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['used', 'usedBy', 'usedAt'])
        )
      );

      allow delete: if signedIn() && resource.data.createdBy == request.auth.uid;
    }

    // ─────────────────────────────────────────────────────────────────
    // MEDICAL EVENTS
    // ─────────────────────────────────────────────────────────────────

    match /medical_events/{eventId} {
      // SECURITY: userId validated on create to prevent IDOR
      allow create: if canAccessPetById(request.resource.data.petId)
        && request.resource.data.userId == request.auth.uid;
      allow read: if canAccessPetById(resource.data.petId);
      // SECURITY: petId and userId are immutable after creation
      allow update: if canAccessPetById(resource.data.petId)
        && request.resource.data.petId == resource.data.petId
        && request.resource.data.userId == resource.data.userId;
      allow delete: if canAccessPetById(resource.data.petId);
    }

    // ─────────────────────────────────────────────────────────────────
    // CLINICAL EVENTS
    // SECURITY NOTE: clinical_events can be pet-scoped OR user-scoped
    // (AI triage sessions not yet tied to a specific pet).
    // For pet-scoped: enforce canAccessPetById.
    // For user-scoped (no petId): enforce own userId + immutability on update.
    // ─────────────────────────────────────────────────────────────────

    match /clinical_events/{eventId} {
      allow create: if
        (request.resource.data.petId is string && canAccessPetById(request.resource.data.petId)) ||
        // User-scoped triage session (petId absent): only owner can create
        (signedIn() && request.resource.data.userId == request.auth.uid);

      allow read, delete: if
        (resource.data.petId is string && canAccessPetById(resource.data.petId)) ||
        (signedIn() && resource.data.userId == request.auth.uid);

      // SECURITY: prevent userId reassignment on update (matches medical_events pattern)
      allow update: if
        (
          resource.data.petId is string
          && canAccessPetById(resource.data.petId)
          && request.resource.data.petId == resource.data.petId
          && request.resource.data.userId == resource.data.userId
        ) ||
        (
          signedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          // User-scoped events cannot be promoted to pet-scoped via update
          && !(request.resource.data.petId is string && resource.data.petId == null)
        );
    }

    // ─────────────────────────────────────────────────────────────────
    // CLINICAL DATA (pet-scoped, all follow same pattern)
    // ─────────────────────────────────────────────────────────────────

    match /pending_actions/{actionId} {
      allow create: if canAccessPetById(request.resource.data.petId);
      allow read, update, delete: if canAccessPetById(resource.data.petId);
    }

    match /pending_reviews/{reviewId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.petId is string && canAccessPetById(resource.data.petId))
      );
    }

    match /medications/{medicationId} {
      allow create: if canAccessPetById(request.resource.data.petId);
      allow read: if canAccessPetById(resource.data.petId);
      // SECURITY: petId immutable after creation
      allow update: if canAccessPetById(resource.data.petId)
        && request.resource.data.petId == resource.data.petId;
      allow delete: if canAccessPetById(resource.data.petId);
    }

    match /appointments/{appointmentId} {
      allow create: if canAccessPetById(request.resource.data.petId);
      allow read: if canAccessPetById(resource.data.petId);
      // SECURITY: petId immutable after creation
      allow update: if canAccessPetById(resource.data.petId)
        && request.resource.data.petId == resource.data.petId;
      allow delete: if canAccessPetById(resource.data.petId);
    }

    match /clinical_conditions/{conditionId} {
      allow create: if canAccessPetById(request.resource.data.petId);
      allow read, update, delete: if canAccessPetById(resource.data.petId);
    }

    // medication_intakes — registro append-only de "tomado HOY"
    // Cross-device sync para PendienteHoyCard. No se actualizan, solo se crean
    // (audit trail). Owner puede borrar para corregir errores; co-tutor no.
    match /medication_intakes/{intakeId} {
      allow create: if canAccessPetById(request.resource.data.petId)
        && request.resource.data.takenBy == request.auth.uid;
      allow read: if canAccessPetById(resource.data.petId);
      allow update: if false; // append-only
      allow delete: if isPetOwnerById(resource.data.petId);
    }

    match /diagnoses/{diagnosisId} {
      allow create: if canAccessPetById(request.resource.data.petId);
      allow read, update, delete: if canAccessPetById(resource.data.petId);
    }

    match /treatments/{treatmentId} {
      allow create: if canAccessPetById(request.resource.data.petId);
      allow read, update, delete: if canAccessPetById(resource.data.petId);
    }

    match /clinical_alerts/{alertId} {
      allow create: if canAccessPetById(request.resource.data.petId);
      allow read, update, delete: if canAccessPetById(resource.data.petId);
    }

    match /clinical_review_drafts/{reviewId} {
      allow create: if canAccessPetById(request.resource.data.petId);
      allow read, update, delete: if canAccessPetById(resource.data.petId);
    }

    match /clinical_episodes/{episodeId} {
      allow create: if canAccessPetById(request.resource.data.petId);
      allow read, update, delete: if canAccessPetById(resource.data.petId);
    }

    match /clinical_profile_snapshots/{snapshotId} {
      allow create: if canAccessPetById(request.resource.data.petId);
      allow read, update, delete: if canAccessPetById(resource.data.petId);
    }

    // ─────────────────────────────────────────────────────────────────
    // VET MODE
    // SECURITY: vetId == request.auth.uid enforces isolation between vets.
    // Vets can only read/write their own consultations and profile.
    // Tutor data is NOT accessible via these collections — vet mode is
    // a separate identity layer that does not cross into pet/user data.
    // ─────────────────────────────────────────────────────────────────

    match /vetProfiles/{vetId} {
      // Any authenticated user can create their own vet profile (pending verification)
      allow create: if signedIn() && request.auth.uid == vetId
        && request.resource.data.verified == false;
      allow read: if signedIn() && request.auth.uid == vetId;
      // SECURITY: vetId path must match auth UID; verified flag can only be set by admin
      allow update: if (signedIn() && request.auth.uid == vetId
          && request.resource.data.keys().hasOnly([
            'fullName', 'specialty', 'matricula', 'patientsCount',
            'phone', 'address', 'bio', 'updatedAt'
          ]))
        || isAdmin();
      allow delete: if isAdmin();
    }

    match /consultations/{consultationId} {
      // Only the vet who owns the consultation can create/read/update
      allow create: if signedIn()
        && request.resource.data.vetId == request.auth.uid
        && request.resource.data.keys().hasAll(['vetId', 'petName', 'tutorName', 'reason', 'status', 'createdAt'])
        && request.resource.data.status == 'pending';
      allow read: if signedIn() && resource.data.vetId == request.auth.uid;
      // SECURITY: vetId immutable; status transitions are controlled
      allow update: if signedIn()
        && resource.data.vetId == request.auth.uid
        && request.resource.data.vetId == resource.data.vetId
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if signedIn() && resource.data.vetId == request.auth.uid;
    }

    // ─────────────────────────────────────────────────────────────────
    // COMMUNITY MODULE
    // SECURITY NOTE: Community collections use `allow read: if signedIn()`
    // which means all authenticated users can see location data (GeoPoint).
    // This is intentional — the Comunidad feature requires geo visibility
    // for lost pet alerts, adoption matching, and nearby sightings.
    // Mitigation: location precision is limited at write time by the app layer.
    // ─────────────────────────────────────────────────────────────────

    match /lost_pets/{reportId} {
      allow create: if signedIn()
        && request.resource.data.reportedBy == request.auth.uid;
      allow read: if signedIn();
      allow update: if signedIn() && resource.data.reportedBy == request.auth.uid;
      allow delete: if signedIn() && resource.data.reportedBy == request.auth.uid;
    }

    match /lost_pet_sightings/{sightingId} {
      allow create: if signedIn() && request.resource.data.reportedBy == request.auth.uid;
      allow read: if signedIn();
      allow update, delete: if signedIn() && resource.data.reportedBy == request.auth.uid;
    }

    match /adoption_listings/{listingId} {
      allow create: if signedIn() && request.resource.data.listedBy == request.auth.uid;
      allow read: if signedIn();
      allow update, delete: if signedIn() && resource.data.listedBy == request.auth.uid;
    }

    // ─── COMMUNITY: Búsqueda Activa (persistent search alerts) ───
    // Max 3 active alerts per user enforced at app layer; expires in 30 days.
    match /search_alerts/{alertId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'active'
        && request.resource.data.keys().hasAll(['userId', 'species', 'radius', 'status', 'createdAt', 'expiresAt']);
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      // SECURITY: userId and createdAt are immutable
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // ─────────────────────────────────────────────────────────────────
    // USER DATA (preferences, gamification, places)
    // ─────────────────────────────────────────────────────────────────

    match /user_preferences/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /user_gamification/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /places/{placeId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /place_reviews/{reviewId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn();
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // ─────────────────────────────────────────────────────────────────
    // GMAIL INGESTION (temporary — backend-only write)
    // ─────────────────────────────────────────────────────────────────

    match /gmail_raw_documents_tmp/{docId} {
      allow read, delete: if signedIn() && resource.data.user_id == request.auth.uid;
      allow create, update: if false; // Cloud Functions only
    }
    match /gmail_attachment_extract_tmp/{docId} {
      allow read, delete: if signedIn() && resource.data.user_id == request.auth.uid;
      allow create, update: if false;
    }
    match /gmail_ingestion_sessions/{sessionId} {
      allow read: if signedIn() && resource.data.user_id == request.auth.uid;
      allow create, update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────────
    // NOTIFICATIONS & SCHEDULING
    // ─────────────────────────────────────────────────────────────────

    match /reminders/{reminderId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /scheduled_notifications/{id} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.petId != null && canAccessPetById(resource.data.petId))
      );
    }

    match /scheduled_reminders/{id} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.petId is string && canAccessPetById(resource.data.petId))
      );
    }

    match /dose_events/{id} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.petId is string && canAccessPetById(resource.data.petId))
      );
    }

    // ─────────────────────────────────────────────────────────────────
    // VERIFIED REPORTS (digital passport export)
    // ─────────────────────────────────────────────────────────────────

    // ─────────────────────────────────────────────────────────────────
    // LEARNING VIDEOS (curated educational content)
    // Read: any authenticated user (shared content, no PII).
    // Write: admin only — clients cannot mutate the curated catalog.
    // ─────────────────────────────────────────────────────────────────

    match /learningVideos/{videoId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /verified_reports/{reportId} {
      allow read: if signedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.generatedAt is string
        && request.resource.data.summary is string
        && request.resource.data.summary.size() <= 1200
        && request.resource.data.keys().hasOnly([
          "ownerId",
          "generatedAt",
          "summary",
          "visibility",
          "isRedactedPublic",
          "certificateType",
          "documentCount",
          "includesAiNarrative",
          "sourceTruthLevel",
          "verificationVersion"
        ]);
      allow update, delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }
  }
}
